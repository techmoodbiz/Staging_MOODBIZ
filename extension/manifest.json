{
  "manifest_version": 3,
  "name": "Moodbiz Rank Checker",
  "version": "2.0.0",
  "description": "Kiểm tra thứ hạng từ khóa trên Google thực tế - Moodbiz.vn",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "alarms",
    "windows"
  ],
  "host_permissions": [
    "http://localhost:*/*",
    "http://127.0.0.1:*/*",
    "https://staging-backend-one.vercel.app/*",
    "https://www.google.com/*",
    "https://google.com/*",
    "https://www.google.com.vn/*",
    "https://staging.moodbiz.vn/*",
    "https://brandchecker.moodbiz.agency/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost:*/*",
        "http://127.0.0.1:*/*",
        "https://staging.moodbiz.vn/*",
        "https://rank.moodbiz.vn/*",
        "https://brandchecker.moodbiz.agency/*"
      ],
      "js": ["config.js", "content-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Rank Checker",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
