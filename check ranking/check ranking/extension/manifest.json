{
  "manifest_version": 3,
  "name": "Moodbiz Rank Checker",
  "version": "1.3.0",
  "description": "Kiểm tra thứ hạng từ khóa trên Google thực tế - Moodbiz.vn",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "alarms",
    "windows"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://rank.moodbiz.vn/*",
    "https://www.google.com/*",
    "https://google.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5000/*",
        "https://rank.moodbiz.vn/*"
      ],
      "js": ["config.js", "content-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Rank Checker"
  },
  "background": {
    "service_worker": "background.js"
  }
}
